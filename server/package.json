{
  "name": "compdfkit-server",
  "version": "4.1.0",
  "scripts": {
    "build": "nest build",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e:sdk": "ts-node scripts/sdk-smoke.ts",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "init:db": "node dist/src/scripts/init-db.js",
    "init:db:dev": "ts-node src/scripts/init-db.ts",
    "reset:password": "node dist/src/scripts/reset-password.js",
    "reset:password:dev": "ts-node src/scripts/reset-password.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.2.0",
    "@types/js-yaml": "^4.0.9",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "form-data": "^4.0.0",
    "ioredis": "^5.3.2",
    "js-yaml": "^5.2.1",
    "multer": "^2.0.2",
    "mysql2": "^3.7.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@swc/core": "^1.15.43",
    "@types/bcrypt": "^6.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.9"
  }
}
