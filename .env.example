PORT=8080
NODE_ENV=production
# The published base images are linux/amd64. Keep this default on Apple Silicon
# so Docker Desktop can run them with amd64 emulation.
COMPDF_IMAGE_PLATFORM=linux/amd64
# Secret for the server's own admin-session JWT (change in prod):
JWT_SECRET=change-me-in-prod

# ---- MySQL (owned by server; infra container) ----
DATABASE_HOST=compdf-infra
DATABASE_PORT=3306
DATABASE_USER=compdfkit
DATABASE_PASSWORD=compdfkit-pass-2026
DATABASE_NAME=compdfkit

# ---- Redis ----
REDIS_HOST=compdf-infra
REDIS_PORT=6379

# ---- Upstream SDK services ----
# The published compdf-app image exposes conversion APIs on :7000 and PDF SDK
# /v1/sync/* APIs on :7001.
COMPDF_SDK_BASE_URL=http://compdf-app:7000
PDF_SDK_BASE_URL=http://compdf-app:7001
CONVERSION_BASE_URL=http://compdf-app:7000

# ---- License ----
# Raw license token (JWT) injected by server into the X-ComPDF-License header
# on every upstream SDK call. The signed token (configs/license.jwt) is the
# authoritative source; this env is the deployment-time override. Enforced by the
# closed-source app, NOT by the server.
LICENSE_KEY=
LICENSE_TOKEN_PATH=/app/configs/license.jwt

COMPDF_LICENSE_
COMPDF_LICENSE_SECRET=
COMPDF_LICENSE_APPID=com.compdfkit.conversion
COMPDF_AI_MODEL=/opt/compdf_sdk/models/documentai.model
